    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "custom": {
            "axisPlacement": "auto",
            "axisWidth": 0,
            "fillOpacity": 70,
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineWidth": 3,
            "spanNulls": false
          },
          "mappings": [
            {
              "options": {
                "pattern": ".*rc.*",
                "result": {
                  "color": "yellow",
                  "index": 0
                }
              },
              "type": "regex"
            },
            {
              "options": {
                "pattern": ".*alpha.*",
                "result": {
                  "color": "red",
                  "index": 1
                }
              },
              "type": "regex"
            },
            {
              "options": {
                "pattern": ".*beta.*",
                "result": {
                  "color": "orange",
                  "index": 2
                }
              },
              "type": "regex"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "gte",
                "reducer": "allIsZero",
                "value": 0
              }
            },
            "properties": [
              {
                "id": "custom.hideFrom",
                "value": {
                  "legend": false,
                  "tooltip": false,
                  "viz": false
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 47,
      "maxDataPoints": 200,
      "options": {
        "alignValue": "center",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "auto",
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "expr": "max by(instance, version) (last_over_time(x_ui_xray_version{instance=\"$instance\"}[$__interval]))\r\nor vector(0)",
          "format": "table",
          "instant": false,
          "legendFormat": "__auto",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "xray version history",
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "instance",
            "emptyValue": "null",
            "rowField": "Time",
            "valueField": "version"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Value": true
            },
            "includeByName": {},
            "indexByName": {},
            "renameByName": {
              "Value": "",
              "version": ""
            }
          }
        }
      ],
      "type": "state-timeline"
    },
    {
      "datasource": {
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
